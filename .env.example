# Web (Vite) — copy to .env and fill values (never commit .env)

#VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: canonical + OG URLs in index.html (defaults to www.dreemystar.com locally).
# Set in Vercel Production when the live domain is www (overrides VERCEL_URL-based injection).
# VITE_PUBLIC_SITE_ORIGIN=https://www.dreemystar.com

# --- Vercel: Preview works but Production does not ---
# Vite bakes VITE_* at build time. In Vercel → Settings → Environment Variables, set the SAME
# keys for "Production" as for "Preview" (each scope is separate). After adding Production vars,
# redeploy Production (a promotion alone does not rebuild; a new build is needed if Prod was built
# without those vars).
#
# Supabase → Authentication → URL Configuration: set Site URL to your live origin (e.g.
# https://www.dreemystar.com) and add every browser origin you use to "Redirect URLs", including:
#   https://www.dreemystar.com/**   https://dreemystar.com/**
#   https://*.vercel.app/**         (preview deployments)
# OAuth and email links use window.location.origin — any new domain must be listed or auth/API fails.

# Show Pawapay payment buttons (requires Supabase Edge Function secrets + DB migration)
# VITE_ENABLE_PAWAPAY=true

# Supabase Edge Function secrets (set via dashboard / CLI, not in Vite .env):
#
# --- PawaPay production (after go-live approval) ---
# PAWAPAY_BASE_URL=https://api.pawapay.io
# PAWAPAY_API_TOKEN=<production token from PawaPay dashboard (API tokens)>
# SITE_URL=https://your-live-frontend.example
# PAWAPAY_RETURN_URL_BASE=https://your-live-frontend.example  # optional; use if app lives under a path, e.g. https://cdn.example.com/myapp
# PAWAPAY_RETURN_URL_ORIGIN=  # optional; same as SITE_URL unless SITE_URL is wrong for browser redirects
# In PawaPay dashboard → Callback URLs: set deposit callback to EXACTLY (same project ref + token):
#   https://YOUR_PROJECT_REF.supabase.co/functions/v1/pawapay-deposit-callback?token=YOUR_SECRET
# Set the same secret in Supabase as: PAWAPAY_CALLBACK_TOKEN=YOUR_SECRET
# Redeploy at least: pawapay-deposit-callback, create-pawapay-payment, create-tip-pawapay-payment,
#   refresh-mobile-money-capabilities — then invoke refresh so mobile_money_capability_snapshots matches prod.
#
# Sandbox defaults in code use https://api.sandbox.pawapay.io when PAWAPAY_BASE_URL is unset.
#
# SITE_URL / return URLs (Stripe + PawaPay payment page)
# PAWAPAY_ALLOWED_COUNTRIES=["GHA","KEN","UGA"]  # JSON array, OR comma-separated: GHA,KEN,UGA (same alpha-3 codes)
# Or single-market: PAWAPAY_PAYMENT_COUNTRY=GHA
# Settlement amount for Payment Page: USD × rate, as PAWAPAY_LOCAL_CURRENCY (default XOF for FCFA).
# PAWAPAY_LOCAL_CURRENCY=XOF
# PAWAPAY_USD_TO_LOCAL_RATE=655
# PAWAPAY_AMOUNT_DECIMAL_PLACES=2  # use 0 only if your corridor rejects fractional amounts
# Optional: PAWAPAY_DIAL_PREFIX_MAP_JSON={"263":"ZWE"} to extend E.164 prefix → alpha-3
